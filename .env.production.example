# === Ports (auf dem Host) ===
FRONTEND_PORT=8080
BACKEND_PORT=3001

# === Supabase (Backend - Service Key) ===
SUPABASE_URL=https://odkinehrlypuyxtlqwkt.supabase.co
SUPABASE_SERVICE_KEY=sb_secret_...

# === Supabase (Frontend - Anon Key, wird beim Build eingebettet) ===
VITE_SUPABASE_URL=https://odkinehrlypuyxtlqwkt.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_...

# === API URL (wie der Browser das Backend erreicht) ===
# Muss die öffentliche URL des Backends sein (z.B. über Caddy Subdomain)
VITE_API_BASE_URL=https://aas-api.deine-domain.de

# === Turnstile (optional) ===
VITE_TURNSTILE_SITE_KEY=

# === CORS (welche Origin darf das Backend aufrufen) ===
CORS_ORIGIN=https://aas-editor.deine-domain.de
